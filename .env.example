# papergirl 配置 — 复制为 .env 并填值；.env 不进 git，权限 0600

# 推稿适配器：wechat（默认，需下面的公众号凭证）| vault（零凭证，导出本地 markdown bundle）
# 没有微信账号想先跑通全流程，设 PUBLISHER=vault 即可（详见 tools/publishers/README.md）。
# PUBLISHER=wechat

# 公众号凭证（mp.weixin.qq.com → 开发 → 基本配置）；PUBLISHER=vault 时不需要
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 微信 API 出站代理（该 IP 必须在公众号「IP 白名单」里）。
# 本机出口 IP 已直接加白时可留空走直连。
WECHAT_PROXY_URL=

# 生图网关：OpenAI-compatible chat/completions，返回 base64 data URI 或 markdown 图链
IMAGE_API_URL=
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2

# 封面默认外观（可选）
# COVER_ASPECT_RATIO=2.35:1
# COVER_BRAND_COLOR=#8087EA

# last30days 可选增强源（不填也能跑：Reddit/HN/GitHub 免费）
# SCRAPECREATORS_API_KEY=
# OPENROUTER_API_KEY=
# BRAVE_API_KEY=

# X 源：不在这里填。AUTH_TOKEN/CT0 由 tools/x_cookies.py 从已登录的浏览器原生提取，
# 写到 gitignored 的 state/x-cookies.env，episode-runner 自动 source。详见 CLAUDE.md。

# 推送通知：让自动跑完的 episode 喊到你（留空=只本地打印不推送）
# NOTIFY_KIND=wecom        # wecom(企业微信群机器人,官方推荐)|feishu|bark|slack|generic
# NOTIFY_WEBHOOK=           # wecom 填完整 https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=..
