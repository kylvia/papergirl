# 凭证
.env
*.env
!.env.example
state/x-cookies.env

# 运行产物
state/runs/*
!state/runs/.gitkeep
drafts/*
!drafts/.gitkeep
*.log

# 依赖与缓存
node_modules/
__pycache__/
*.pyc
.venv/

# 系统
.DS_Store

# 全局 gitignore 忽略了 .claude/，本仓 vendored skill 必须入库，反向豁免
!.claude/
!.claude/**
# 但 .claude 下的运行缓存仍排除（上面的 !.claude/** 会把它们带回来）
.claude/**/__pycache__/
.claude/**/*.pyc

# 账号效果数据（真实数字，不入库）
state/metrics.json

# 历史基线（真实账号数据）
state/baseline.md
